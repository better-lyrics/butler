{
	"name": "butler",
	"version": "0.1.0",
	"private": true,
	"license": "GPL-3.0-or-later",
	"type": "module",
	"engines": { "node": ">=22.12.0" },
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist/index.js --tsconfig=tsconfig.json && cp src/db/schema.sql dist/schema.sql",
		"start": "node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write ."
	},
	"dependencies": {
		"discord.js": "^14.26.0",
		"pg": "^8.13.0",
		"youtubei.js": "^17.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.0.0",
		"@types/pg": "^8.11.0",
		"esbuild": "^0.25.0",
		"pg-mem": "^3.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
